{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "amux",
  "version": "0.2.0",
  "identifier": "kr.co.enki.amux",
  "mainBinaryName": "amux-app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "bun run dev",
    "beforeBuildCommand": "bun run build"
  },
  "app": {
    "windows": [
      {
        "title": "amux",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "publisher": "Wonjoon Choi",
    "category": "DeveloperTool",
    "shortDescription": "AI 에이전트 병렬 터미널",
    "longDescription": "amux: a terminal for running AI coding agents in parallel — workspaces, splits, agent status, notifications, and a Unix-socket CLI.",
    "linux": {
      "deb": {
        "files": {
          "/usr/bin/amux": "../target/release/amux"
        }
      }
    }
  }
}
